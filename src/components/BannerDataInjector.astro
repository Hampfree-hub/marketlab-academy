---
// BannerDataInjector.astro
// Единый источник данных для клиентских баннеров.
// Импортирует BANNER_TRANSLATIONS из ad-banners.ts и рендерит JS-объект в <script>.
// Это УСТРАНЯЕТ дублирование: не нужно копировать bannerTranslations в BlogPost.astro.

import { BANNER_TRANSLATIONS } from '../config/ad-banners';

// Преобразуем TypeScript-объект в JSON для клиентского JS
const bannerDataJson = JSON.stringify(BANNER_TRANSLATIONS, null, 0);
---

<script is:inline define:vars={{ bannerDataJson }}>
  // Данные баннеров — автогенерированы из ad-banners.ts (НЕ редактировать вручную!)
  // ВАЖНО: объявляем в глобальной области (без var/let/const), чтобы BlogPost.astro мог читать
  window.BANNER_DATA = JSON.parse(bannerDataJson);
</script>
