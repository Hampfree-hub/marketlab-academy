---
// Компактный реферальный баннер (728×150, адаптивный)
// Переиспользуемый компонент для вставки в статьи

import type { AdBanner } from '../config/ad-banners';

export interface Props {
  banner: AdBanner;
  lang?: 'ru' | 'en' | 'es';
  className?: string;
}

const { banner, lang = 'ru', className = '' } = Astro.props;

// Формируем финальную ссылку
const finalLink = banner.link.startsWith('/') 
  ? banner.link.replace('{lang}', lang)
  : banner.link;
---

<div class={`ad-banner-container ${className}`}>
  <a
    href={finalLink}
    target="_blank"
    rel="nofollow sponsored"
    class="ad-banner-link"
    style={{
      '--bg-start': banner.colors.bgStart,
      '--bg-end': banner.colors.bgEnd,
      '--text-color': banner.colors.text,
      '--cta-bg': banner.colors.ctaBg,
      '--cta-text': banner.colors.ctaText,
      '--border-color': banner.colors.border,
    }}
  >
    <div class="ad-banner-content">
      <div class="text-block">
        <div class="title">{banner.title}</div>
        <div class="subtitle">{banner.subtitle}</div>
      </div>
      <div class="cta">{banner.cta}</div>
    </div>
  </a>
</div>

<style>
  .ad-banner-container {
    width: 100%;
    max-width: 728px;
    margin: 2rem auto;
    padding: 0 1rem;
    display: block;
  }

  .ad-banner-link {
    display: block;
    background: linear-gradient(135deg, var(--bg-start), var(--bg-end));
    border: 2px solid var(--border-color);
    border-radius: 4px;
    padding: 12px 20px;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    position: relative;
    overflow: hidden;
    width: 100%;
    box-sizing: border-box;
  }

  .ad-banner-link:hover {
    transform: scale(1.02);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
  }

  /* Scanlines effect */
  .ad-banner-link::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: repeating-linear-gradient(
      rgba(0, 0, 0, 0.05),
      rgba(0, 0, 0, 0.05) 1px,
      transparent 1px,
      transparent 4px
    );
    pointer-events: none;
    z-index: 1;
  }

  /* Border frame */
  .ad-banner-link::after {
    content: "";
    position: absolute;
    top: 6px;
    left: 6px;
    right: 6px;
    bottom: 6px;
    border: 2px solid var(--border-color);
    border-radius: 4px;
    pointer-events: none;
    z-index: 1;
  }

  .ad-banner-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    width: 100%;
  }

  .text-block {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 4px;
    overflow: hidden;
    min-width: 0; /* Позволяет text-overflow работать */
  }

  .title {
    font-family: 'Press Start 2P', monospace;
    font-size: clamp(10px, 1.5vw + 8px, 12px);
    color: var(--text-color);
    line-height: 1.3;
    text-transform: uppercase;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .subtitle {
    font-family: 'JetBrains Mono', monospace;
    font-size: clamp(8px, 1vw + 6px, 9px);
    color: var(--text-color);
    opacity: 0.9;
    line-height: 1.4;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .cta {
    display: inline-block;
    font-family: 'Press Start 2P', monospace;
    font-size: clamp(8px, 1vw + 6px, 9px);
    background: var(--cta-bg);
    color: var(--cta-text);
    padding: 6px 14px;
    border: 1px solid #000;
    border-radius: 3px;
    white-space: nowrap;
    flex-shrink: 0;
    transition: transform 0.1s ease, box-shadow 0.1s ease;
  }

  .ad-banner-link:hover .cta {
    transform: translate(-2px, -2px);
    box-shadow: 4px 4px 0 rgba(0, 0, 0, 0.3);
  }

  /* Mobile responsive */
  @media (max-width: 480px) {
    .ad-banner-container {
      margin: 1.5rem auto;
      padding: 0 0.75rem;
    }

    .ad-banner-link {
      padding: 10px 14px;
    }

    .ad-banner-content {
      gap: 10px;
    }

    .cta {
      padding: 5px 10px;
    }
  }

  /* Очень узкие экраны */
  @media (max-width: 360px) {
    .ad-banner-container {
      padding: 0 0.5rem;
    }

    .ad-banner-link {
      padding: 8px 12px;
    }

    .title {
      font-size: 9px;
    }

    .subtitle {
      font-size: 7px;
    }

    .cta {
      font-size: 7px;
      padding: 4px 8px;
    }
  }
</style>
