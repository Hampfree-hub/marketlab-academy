---
// Компактный реферальный баннер (адаптивный, 8-bit стиль)
// Переиспользуемый компонент для вставки в статьи
// Стиль как у Banner.astro: рамка категории с box-shadow

import type { AdBanner } from '../config/ad-banners';

export interface Props {
  banner: AdBanner;
  lang?: 'ru' | 'en' | 'es';
  className?: string;
}

const { banner, lang = 'ru', className = '' } = Astro.props;

// Формируем финальную ссылку
const finalLink = banner.link.startsWith('/') 
  ? banner.link.replace('{lang}', lang)
  : banner.link;
---

<div class={`ad-banner-container ${className}`}>
  <a
    href={finalLink}
    target="_blank"
    rel="nofollow sponsored"
    class="ad-banner-link"
    style={{
      '--bg-start': banner.colors.bgStart,
      '--bg-end': banner.colors.bgEnd,
      '--text-color': banner.colors.text,
      '--cta-bg': banner.colors.ctaBg,
      '--cta-text': banner.colors.ctaText,
      '--border-color': banner.colors.border,
    }}
  >
    <div class="ad-banner-content">
      <div class="text-block">
        <div class="title">{banner.title}</div>
        <div class="subtitle">{banner.subtitle}</div>
      </div>
      <div class="cta">
        {banner.cta.replace('→', '')}
        <span class="cta-arrow"></span>
      </div>
    </div>
  </a>
</div>

<style>
  .ad-banner-container {
    width: 100%;
    max-width: 100%;
    margin: 2rem auto;
    padding: 0 1rem;
    display: block;
    box-sizing: border-box;
  }

  .ad-banner-link {
    display: block;
    background: linear-gradient(135deg, var(--bg-start), var(--bg-end));
    border-radius: 0;
    padding: 20px 24px;
    text-decoration: none !important;
    position: relative;
    overflow: hidden;
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
  }

  /* Scanlines effect (как в Banner.astro) */
  .ad-banner-link::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: repeating-linear-gradient(
      rgba(0, 0, 0, 0.05),
      rgba(0, 0, 0, 0.05) 1px,
      transparent 1px,
      transparent 4px
    );
    pointer-events: none;
    z-index: 1;
  }

  /* Border frame (как рамка категории в Banner.astro) */
  .ad-banner-link::after {
    content: "";
    position: absolute;
    top: 6px;
    left: 6px;
    right: 6px;
    bottom: 6px;
    border: 2px solid var(--border-color);
    border-radius: 0;
    pointer-events: none;
    z-index: 1;
  }

  .ad-banner-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    width: 100%;
  }

  .text-block {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 6px;
    overflow: visible;
    min-width: 0;
  }

  .title {
    font-family: 'Press Start 2P', monospace;
    font-size: clamp(12px, 2vw + 10px, 16px);
    color: var(--text-color);
    line-height: 1.4;
    text-transform: uppercase;
    white-space: normal;
    overflow: visible;
    text-overflow: clip;
    margin: 0;
    word-wrap: break-word;
    overflow-wrap: break-word;
  }

  .subtitle {
    font-family: 'JetBrains Mono', monospace;
    font-size: clamp(10px, 1.5vw + 8px, 12px);
    color: var(--text-color);
    opacity: 0.9;
    line-height: 1.5;
    white-space: normal;
    overflow: visible;
    text-overflow: clip;
    margin: 0;
    word-wrap: break-word;
    overflow-wrap: break-word;
  }

  .cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: 'Press Start 2P', monospace;
    font-size: clamp(10px, 1.5vw + 8px, 12px);
    background: var(--cta-bg);
    color: var(--cta-text);
    padding: 8px 16px;
    border: 2px solid #000;
    box-shadow: 4px 4px 0 rgba(0, 0, 0, 0.3);
    text-transform: uppercase;
    white-space: nowrap;
    flex-shrink: 0;
    margin: 0;
  }

  .cta-arrow {
    display: inline-block;
    width: 0;
    height: 0;
    border-top: 5px solid transparent;
    border-bottom: 5px solid transparent;
    border-left: 7px solid currentColor;
    line-height: 0;
    vertical-align: middle;
  }

  /* Mobile responsive */
  @media (max-width: 480px) {
    .ad-banner-container {
      margin: 1.5rem auto;
      padding: 0 0.75rem;
    }

    .ad-banner-link {
      padding: 16px 18px;
    }

    .ad-banner-content {
      gap: 12px;
      flex-wrap: wrap;
      justify-content: center;
      text-align: center;
    }

    .text-block {
      min-width: 100%;
      text-align: center;
    }

    .title {
      font-size: 11px;
      white-space: normal;
      word-wrap: break-word;
    }

    .subtitle {
      font-size: 9px;
      white-space: normal;
      word-wrap: break-word;
    }

    .cta {
      padding: 7px 14px;
      white-space: normal;
      word-wrap: break-word;
      justify-content: center;
    }
  }

  /* Очень узкие экраны */
  @media (max-width: 360px) {
    .ad-banner-container {
      padding: 0 0.5rem;
    }

    .ad-banner-link {
      padding: 14px 16px;
    }

    .title {
      font-size: 10px;
    }

    .subtitle {
      font-size: 8px;
    }

    .cta {
      font-size: 8px;
      padding: 6px 12px;
    }
  }
</style>
